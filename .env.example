# WarungPintar Mobile — environment variables
# Copy this file to .env and fill in the values.
# .env is git-ignored; .env.example is committed as a reference.

# Backend API base URL (no trailing slash)
# Local emulator / simulator:
API_BASE_URL=http://localhost:3001/api
# Real Android device on the same network (replace with your Mac's LAN IP):
# API_BASE_URL=http://192.168.1.x:3001/api
# Staging / production:
# API_BASE_URL=https://api.yourserver.com/api

# ── Google Sign-In ────────────────────────────────────────────────────────────
# The web/server OAuth client ID and the "enabled" flag come from the BACKEND
# (GET /auth/providers), configured in the admin panel "Penyedia Login".
# The backend is the source of truth — nothing to set here for that.
#
# The only on-device value is the iOS native OAuth client ID, because Apple's
# native sign-in needs a compile-time URL scheme. Create it in Google Cloud →
# Credentials → OAuth client ID → iOS (using the app's bundle ID), then add its
# REVERSED_CLIENT_ID as a CFBundleURLScheme in ios/Runner/Info.plist.
# (On Android this is resolved from android/app/google-services.json instead.)
GOOGLE_IOS_CLIENT_ID=

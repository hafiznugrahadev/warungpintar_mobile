# WarungPintar Mobile — environment variables
# Copy this file to .env and fill in the values.
# .env is git-ignored; .env.example is committed as a reference.

# Backend API base URL (no trailing slash)
# Local emulator / simulator:
API_BASE_URL=http://localhost:3001/api
# Real Android device on the same network (replace with your Mac's LAN IP):
# API_BASE_URL=http://192.168.1.x:3001/api
# Staging / production:
# API_BASE_URL=https://api.yourserver.com/api
